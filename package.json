{
  "name": "owned-site-rebuilder-lab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local research harness for reconstructing observable behavior of an owned/authorized browser-based video editor (demo.reactvideoeditor.com). Not for unauthorized targets.",
  "scripts": {
    "capture": "node scripts/capture-site.mjs",
    "probe": "node scripts/probe-features.mjs",
    "bundles": "node scripts/analyze-bundles.mjs",
    "storage": "node scripts/inspect-storage.mjs",
    "reports": "node scripts/generate-reports.mjs",
    "visual-compare": "node scripts/visual-compare.mjs",
    "fetch:bundles": "node scripts/fetch-public-bundles.mjs",
    "analyze:deep-bundles": "node scripts/deep-bundle-analysis.mjs",
    "instrument:runtime": "node scripts/runtime-instrumentation.mjs",
    "probe:single-import": "node scripts/single-file-import-probe.mjs",
    "mine:selectors": "node scripts/selector-miner.mjs",
    "decode:state": "node scripts/decode-state-stores.mjs",
    "coverage:actions": "node scripts/action-coverage-map.mjs",
    "audit:proof": "node scripts/audit-proof-quality.mjs",
    "scan:target": "node scripts/scan-target-artifacts.mjs",
    "probe:stacks": "node scripts/action-stack-trace-probe.mjs",
    "map:stacks": "node scripts/map-stack-frames-to-bundles.mjs",
    "coverage:debug": "node scripts/coverage-debug.mjs",
    "coverage:cdp": "node scripts/action-coverage-cdp.mjs",
    "correlate:features": "node scripts/correlate-features-to-code.mjs",
    "react:regions": "node scripts/react-region-map.mjs",
    "probe:import-timeline": "node scripts/import-timeline-hardening.mjs",
    "deep": "npm run fetch:bundles && npm run analyze:deep-bundles && npm run instrument:runtime && npm run coverage:actions && npm run probe:single-import && npm run mine:selectors && npm run decode:state && npm run audit:proof && npm run scan:target",
    "deep:correlation": "npm run probe:stacks && npm run map:stacks && npm run coverage:debug && npm run coverage:cdp && npm run correlate:features && npm run react:regions && npm run probe:import-timeline",
    "test": "playwright test",
    "test:visual": "playwright test tests/visual-baseline.spec.mjs",
    "test:features": "playwright test tests/feature-parity-plan.spec.mjs",
    "test:deep": "playwright test tests/deep-runtime-proof.spec.mjs tests/single-import-proof.spec.mjs tests/bundle-analysis-proof.spec.mjs",
    "test:correlation": "playwright test tests/code-correlation-proof.spec.mjs tests/action-stack-proof.spec.mjs tests/import-timeline-proof.spec.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "acorn": "^8.17.0",
    "acorn-walk": "^8.3.5",
    "es-module-lexer": "^2.3.0",
    "fast-glob": "^3.3.3",
    "js-beautify": "^2.0.3",
    "pixelmatch": "^6.0.0",
    "playwright": "^1.45.0",
    "pngjs": "^7.0.0",
    "source-map": "^0.7.6",
    "terser": "^5.49.0"
  }
}
